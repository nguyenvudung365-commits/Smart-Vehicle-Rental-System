// Prisma schema cho Mioto Clone
// Buoi 5: Them Kyc, Booking, PaymentCard, upload anh MinIO
// Map cac ENUM sang snake_case de khop voi CREATE TYPE trong mioto_schema.sql

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  renter
  host
  admin

  @@map("user_role")
}

enum KycStatus {
  pending
  approved
  rejected

  @@map("kyc_status")
}

enum VehicleStatus {
  draft
  pending
  approved
  rejected
  inactive

  @@map("vehicle_status")
}

enum TransmissionType {
  manual
  automatic

  @@map("transmission_type")
}

enum FuelType {
  gasoline
  diesel
  electric
  hybrid

  @@map("fuel_type")
}

enum BookingStatus {
  pending_payment
  confirmed
  host_handover   // host đã bàn giao xe, chờ khách xác nhận nhận xe
  in_progress     // khách đã xác nhận nhận xe, đang thuê
  renter_return   // khách đã trả xe, chờ host xác nhận
  completed
  cancelled

  @@map("booking_status")
}

enum CardBrand {
  visa
  mastercard
  jcb
  amex

  @@map("card_brand")
}

// ==================== MODELS ====================

model User {
  id            String    @id @default(uuid()) @db.Uuid
  phone         String    @unique @db.VarChar(15)
  email         String?   @unique @db.VarChar(100)
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  fullName      String    @map("full_name") @db.VarChar(100)
  avatarUrl     String?   @map("avatar_url") @db.VarChar(255)
  birthday      DateTime? @db.Date
  role          UserRole  @default(renter)
  isActive      Boolean   @default(true) @map("is_active")
  referralCode  String?   @unique @map("referral_code") @db.VarChar(10)
  referredBy    String?   @map("referred_by") @db.VarChar(10)
  rewardPoints  Int       @default(0) @map("reward_points")
  pushToken            String?   @map("push_token") @db.VarChar(500)
  deleteRequestedAt    DateTime? @map("delete_requested_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at")

  vehicles             Vehicle[]      @relation("VehicleOwner")
  kyc                  Kyc?
  bookings             Booking[]      @relation("RenterBookings")
  paymentCards         PaymentCard[]
  reviews              Review[]       @relation("RenterReviews")
  notifications        Notification[]
  favorites            Favorite[]
  addresses            Address[]
  pointHistories       PointHistory[]
  renterConversations  Conversation[] @relation("RenterConversations")
  hostConversations    Conversation[] @relation("HostConversations")
  sentMessages         Message[]      @relation("SentMessages")
  hostReviewsGiven     HostReview[]   @relation("HostReviewsGiven")
  hostReviewsReceived  HostReview[]   @relation("HostReviewsReceived")
  blocksGiven          BlockedRenter[] @relation("BlocksGiven")
  blocksReceived       BlockedRenter[] @relation("BlocksReceived")

  @@map("users")
}

model Kyc {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @unique @map("user_id") @db.Uuid
  licenseNumber       String    @map("license_number") @db.VarChar(20)
  fullName            String    @map("full_name") @db.VarChar(100)
  dob                 DateTime? @db.Date
  frontImageUrl       String    @map("front_image_url") @db.VarChar(500)
  frontImageKey       String    @map("front_image_key") @db.VarChar(255)
  backImageUrl        String    @map("back_image_url") @db.VarChar(500)
  backImageKey        String    @map("back_image_key") @db.VarChar(255)
  // CCCD bổ sung (không bắt buộc, nộp cùng đợt hoặc sau)
  cccdNumber          String?   @map("cccd_number") @db.VarChar(20)
  cccdFrontImageUrl   String?   @map("cccd_front_image_url") @db.VarChar(500)
  cccdFrontImageKey   String?   @map("cccd_front_image_key") @db.VarChar(255)
  cccdBackImageUrl    String?   @map("cccd_back_image_url") @db.VarChar(500)
  cccdBackImageKey    String?   @map("cccd_back_image_key") @db.VarChar(255)
  status              KycStatus @default(pending)
  rejectReason        String?   @map("reject_reason")
  submittedAt         DateTime  @default(now()) @map("submitted_at")
  reviewedAt          DateTime? @map("reviewed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("kyc")
}

model Vehicle {
  id             String           @id @default(uuid()) @db.Uuid
  ownerId        String           @map("owner_id") @db.Uuid
  addressId      String?          @map("address_id") @db.Uuid
  brand          String           @db.VarChar(50)
  model          String           @db.VarChar(100)
  year           Int
  transmission   TransmissionType
  fuelType       FuelType         @map("fuel_type")
  seats          Int
  licensePlate   String           @unique @map("license_plate") @db.VarChar(15)
  pricePerDay      Decimal          @map("price_per_day") @db.Decimal(12, 2)
  fuelConsumption  Float?           @map("fuel_consumption")
  kmLimitPerDay    Int?             @map("km_limit_per_day")
  overageFeePerKm  Decimal?         @map("overage_fee_per_km") @db.Decimal(10, 2)
  description    String?
  status         VehicleStatus    @default(draft)
  rejectReason   String?          @map("reject_reason")
  isAvailable    Boolean          @default(true) @map("is_available")
  createdAt      DateTime         @default(now()) @map("created_at")
  approvedAt     DateTime?        @map("approved_at")

  owner          User             @relation("VehicleOwner", fields: [ownerId], references: [id])
  address        Address?         @relation(fields: [addressId], references: [id])
  images         VehicleImage[]
  features       VehicleFeature[]
  bookings       Booking[]
  reviews        Review[]
  favorites      Favorite[]
  conversations  Conversation[]

  @@index([status, isAvailable])
  @@index([pricePerDay])
  @@index([ownerId])
  @@map("vehicles")
}

model VehicleImage {
  id            String   @id @default(uuid()) @db.Uuid
  vehicleId     String   @map("vehicle_id") @db.Uuid
  imageUrl      String   @map("image_url") @db.VarChar(500)
  storageKey    String?  @map("storage_key") @db.VarChar(255)
  isCover       Boolean  @default(false) @map("is_cover")
  displayOrder  Int      @default(0) @map("display_order")
  createdAt     DateTime @default(now()) @map("created_at")

  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@map("vehicle_images")
}

model Address {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  label      String?   @db.VarChar(100)
  province   String    @db.VarChar(100)
  district   String    @db.VarChar(100)
  ward       String    @db.VarChar(100)
  detail     String?   @db.VarChar(255)
  latitude   Decimal?  @db.Decimal(10, 7)
  longitude  Decimal?  @db.Decimal(10, 7)
  isDefault  Boolean   @default(false) @map("is_default")
  createdAt  DateTime  @default(now()) @map("created_at")

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicles   Vehicle[]

  @@index([userId])
  @@map("addresses")
}

model Favorite {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  vehicleId String   @map("vehicle_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([userId, vehicleId])
  @@index([userId])
  @@map("favorites")
}

model Feature {
  id        String           @id @default(uuid()) @db.Uuid
  name      String           @unique @db.VarChar(100)
  icon      String?          @db.VarChar(100)
  category  String?          @db.VarChar(50)

  vehicles  VehicleFeature[]

  @@map("features")
}

model VehicleFeature {
  vehicleId  String   @map("vehicle_id") @db.Uuid
  featureId  String   @map("feature_id") @db.Uuid

  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  feature    Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@id([vehicleId, featureId])
  @@map("vehicle_features")
}

model Booking {
  id             String        @id @default(uuid()) @db.Uuid
  renterId       String        @map("renter_id") @db.Uuid
  vehicleId      String        @map("vehicle_id") @db.Uuid
  voucherId      String?       @map("voucher_id") @db.Uuid
  startDate      DateTime      @map("start_date")
  endDate        DateTime      @map("end_date")
  rentalDays     Int           @map("rental_days")
  pricePerDay    Decimal       @map("price_per_day") @db.Decimal(12, 2)
  subtotal       Decimal       @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @map("discount_amount") @db.Decimal(12, 2)
  voucherDiscount Decimal      @default(0) @map("voucher_discount") @db.Decimal(12, 2)
  totalAmount    Decimal       @map("total_amount") @db.Decimal(12, 2)
  note           String?       @db.VarChar(500)
  status         BookingStatus @default(pending_payment)
  cancelReason          String?  @map("cancel_reason")
  cardLast4             String?  @map("card_last4") @db.VarChar(4)
  handoverImageUrl      String?  @map("handover_image_url") @db.VarChar(500)
  renterReceivedImageUrl String? @map("renter_received_image_url") @db.VarChar(500)
  renterReturnImageUrl  String?  @map("renter_return_image_url") @db.VarChar(500)
  hostReceivedImageUrl  String?  @map("host_received_image_url") @db.VarChar(500)
  paymentOtp            String?  @map("payment_otp") @db.VarChar(6)
  paymentOtpExpiresAt   DateTime? @map("payment_otp_expires_at")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at")

  renter  User    @relation("RenterBookings", fields: [renterId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  voucher Voucher? @relation(fields: [voucherId], references: [id])
  review  Review?
  hostReview HostReview?

  @@index([renterId, status])
  @@index([vehicleId, status, startDate, endDate])
  @@map("bookings")
}

model PaymentCard {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  brand       CardBrand
  last4       String    @db.VarChar(4)
  holderName  String    @map("holder_name") @db.VarChar(100)
  expiryMonth Int       @map("expiry_month")
  expiryYear  Int       @map("expiry_year")
  isDefault   Boolean   @default(false) @map("is_default")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("payment_cards")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String   @db.VarChar(200)
  body      String
  type      String   @db.VarChar(50)
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model Review {
  id        String   @id @default(uuid()) @db.Uuid
  bookingId String   @unique @map("booking_id") @db.Uuid
  renterId  String   @map("renter_id") @db.Uuid
  vehicleId String   @map("vehicle_id") @db.Uuid
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id])
  renter  User    @relation("RenterReviews", fields: [renterId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@map("reviews")
}

model PointHistory {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  points      Int
  type        String   @db.VarChar(50)
  description String   @db.VarChar(200)
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("point_histories")
}

model Conversation {
  id          String    @id @default(uuid()) @db.Uuid
  renterId    String    @map("renter_id") @db.Uuid
  hostId      String    @map("host_id") @db.Uuid
  vehicleId   String?   @map("vehicle_id") @db.Uuid
  lastMessage String?   @map("last_message")
  lastAt      DateTime? @map("last_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  renter   User      @relation("RenterConversations", fields: [renterId], references: [id])
  host     User      @relation("HostConversations", fields: [hostId], references: [id])
  vehicle  Vehicle?  @relation(fields: [vehicleId], references: [id])
  messages Message[]

  @@unique([renterId, hostId])
  @@index([renterId])
  @@index([hostId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  senderId       String       @map("sender_id") @db.Uuid
  text           String
  isRead         Boolean      @default(false) @map("is_read")
  createdAt      DateTime     @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@map("messages")
}

model Voucher {
  id            String    @id @default(uuid()) @db.Uuid
  code          String    @unique @db.VarChar(20)
  discountType  String    @map("discount_type") @db.VarChar(10)  // "percent" | "fixed"
  discountValue Decimal   @map("discount_value") @db.Decimal(12, 2)
  maxDiscount   Decimal?  @map("max_discount") @db.Decimal(12, 2)  // giới hạn tối đa cho loại percent
  minOrderValue Decimal   @default(0) @map("min_order_value") @db.Decimal(12, 2)
  usageLimit    Int?      @map("usage_limit")  // null = không giới hạn
  usedCount     Int       @default(0) @map("used_count")
  expiresAt     DateTime? @map("expires_at")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")

  bookings Booking[]

  @@map("vouchers")
}

model HostReview {
  id        String   @id @default(uuid()) @db.Uuid
  bookingId String   @unique @map("booking_id") @db.Uuid
  hostId    String   @map("host_id") @db.Uuid
  renterId  String   @map("renter_id") @db.Uuid
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id])
  host    User    @relation("HostReviewsGiven", fields: [hostId], references: [id])
  renter  User    @relation("HostReviewsReceived", fields: [renterId], references: [id])

  @@index([renterId])
  @@map("host_reviews")
}

model BlockedRenter {
  id        String   @id @default(uuid()) @db.Uuid
  hostId    String   @map("host_id") @db.Uuid
  renterId  String   @map("renter_id") @db.Uuid
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  host   User @relation("BlocksGiven", fields: [hostId], references: [id])
  renter User @relation("BlocksReceived", fields: [renterId], references: [id])

  @@unique([hostId, renterId])
  @@index([hostId])
  @@map("blocked_renters")
}

model SystemConfig {
  key       String   @id @db.VarChar(50)
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}
